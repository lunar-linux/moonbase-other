      SOURCE_VFY=sha256:24123f3e2beb2246790b5875b9cdd1109481cba4139d63ad824de8f33012041d
        WEB_SITE=https://gnome.pages.gitlab.gnome.org/gi-docgen/
            TYPE=python3
         ENTERED=20220402
         UPDATED=20260313
           SHORT="document generator for GObject based libraries"

cat << EOF
GI-DocGen is a document generator for GObject-based libraries. GObject is the base type
system of the GNOME project. GI-Docgen reuses the introspection data generated by
GObject-based libraries to generate the API reference of these libraries, as well as
other ancillary documentation.
EOF
