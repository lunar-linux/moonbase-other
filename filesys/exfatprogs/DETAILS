          MODULE=exfatprogs
         VERSION=1.3.2
          SOURCE=$MODULE-$VERSION.tar.gz
 SOURCE_URL_FULL=https://github.com/exfatprogs/exfatprogs/archive/refs/tags/$VERSION.tar.gz
      SOURCE_VFY=sha256:4b3e198a2b879da52254f9d4a68accff8001b7b4e5c1860d47ad232e03a2a2d0
        WEB_SITE=https://github.com/exfatprogs/exfatprogs/
