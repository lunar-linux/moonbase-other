          MODULE=zfs
         VERSION=2.4.2
          SOURCE=$MODULE-$VERSION.tar.gz
      SOURCE_URL=https://github.com/openzfs/zfs/releases/download/zfs-$VERSION/
      SOURCE_VFY=sha256:7e260d0e6af295bea4c5e241cac0a1aef07b58d8dd8035f7898ade3b1bbec78f
        WEB_SITE=http://zfsonlinux.org
      MAINTAINER=ratler@lunar-linux.org
         LICENSE=cddl
         ENTERED=20130212
         UPDATED=20260606
           SHORT="The ZFS file system"

cat << EOF
ZFS is an advanced file system and volume manager which was originally
developed for Solaris. It has been successfully ported to FreeBSD and now
there is a functional Linux ZFS kernel port too. The port currently includes
a fully functional and stable SPA, DMU, and ZVOL with a ZFS Posix Layer (ZPL)
on the way.
EOF
