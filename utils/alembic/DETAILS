         MODULE=alembic
        VERSION=1.8.11
         SOURCE=$MODULE-$VERSION.tar.gz
SOURCE_URL_FULL=https://github.com/alembic/alembic/archive/refs/tags/$VERSION.tar.gz
     SOURCE_VFY=sha256:ab299bb4b1894a6675c73fa29940522b54c81a91b1d691ca3470d86b7345ffce
       WEB_SITE=http://www.alembic.io/
        ENTERED=20190814
        UPDATED=20260326
          SHORT="an open computer graphics interchange framework"

cat << EOF
Alembic is an open computer graphics interchange framework. Alembic distills
complex, animated scenes into a non-procedural, application-independent set of
baked geometric results. This distillation of scenes into baked geometry is
exactly analogous to the distillation of lighting and rendering scenes into
rendered image data.
EOF
