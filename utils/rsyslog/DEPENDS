depends libestr
depends json-c
depends liblogging
depends libfastjson
depends zlib

optional_depends protobuf-c \
                 "--enable-impstats --enable-impstats-push"  \
                 "--disable-impstats --disable-impstats-push" \
                 "for periodic output of internal counters, impstats (If you say yes here, also select snappy next)"

optional_depends snappy "" "" \
                 "for compression support with the impstats feature"

optional_depends systemd \
                 "--enable-libsystemd --enable-imjournal"  \
                 "--disable-libsystemd --disable-imjournal" \
                 "for systemd support"

optional_depends jemalloc \
                 "--enable-jemalloc" \
                 "--disable-jemalloc" \
                 "for jemalloc support"

optional_depends gnutls \
                 "--enable-gnutls" \
                 "--disable-gnutls" \
                 "for GnuTLS support"

optional_depends libgcrypt \
                 "--enable-libgcrypt" \
                 "--disable-libgcrypt" \
                 "for log encryption support"

optional_depends librelp \
                 "--enable-relp" \
                 "--disable-relp" \
                 "for Reliable Event Logging Protocol support" \
                 "n"

optional_depends %MYSQL \
                 "--enable-mysql" \
                 "--disable-mysql" \
                 "for MySQL support" \
                 "n"

optional_depends postgresql \
                 "--enable-pgsql" \
                 "--disable-pgsql" \
                 "for PostgreSQL support" \
                 "n"

optional_depends libdbi \
                 "--enable-libdbi" \
                 "--disable-libdbi" \
                 "for libdbi database support" \
                 "n"

optional_depends %KERBEROS \
                 "--enable-gssapi-krb5" \
                 "--disable-gssapi-krb5" \
                 "for kerberos support" \
                 "n"

optional_depends net-snmp \
                 "--enable-snmp" \
                 "--disable-snmp" \
                 "for SNMP support" \
                 "n"

optional_depends xconsole "" "" "for following logs through GUI"
