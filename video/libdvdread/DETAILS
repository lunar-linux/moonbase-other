         MODULE=libdvdread
        VERSION=7.1.1
         SOURCE=$MODULE-$VERSION.tar.xz
     SOURCE_URL=https://download.videolan.org/pub/videolan/libdvdread/$VERSION/
     SOURCE_VFY=sha256:a0d47876548bec806774bbf8dbf20bb19ba139464383156b32eb8e59915b90a9
       WEB_SITE=https://www.videolan.org/developers/libdvdnav.html
           TYPE=meson
        ENTERED=20010927
        UPDATED=20260721
          SHORT="library for reading DVD video disks"

cat << EOF
libdvdread provides a simple foundation for reading DVD video disks.
It provides the functionality that is required to access many DVDs. It
parses IFO files, reads NAV-blocks, and performs CSS authentication and
descrambling.

Note: vlc wants this one instead of the one from chalmers.
EOF
