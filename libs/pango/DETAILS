          MODULE=pango
         VERSION=1.57.1
          SOURCE=$MODULE-$VERSION.tar.xz
      SOURCE_URL=$GNOME_URL/sources/$MODULE/${VERSION%.*}
      SOURCE_VFY=sha256:e65d6d117080dc3aeeb7d8b4b3b518f7383aa2e6cfce23117c623cd624764c2f
        WEB_SITE=http://www.pango.org
         ENTERED=20020313
         UPDATED=20260325
           SHORT="A library for text layout and rendering"

cat << EOF
Pango is a library for the laying out and rendering of text, with an emphasis
on internationalization. Pango can be used anywhere that text layout is needed,
though most of the work on Pango so far has been done in the context of the
GTK+ widget toolkit. Pango forms the core of text and font handling for GTK+.
EOF
