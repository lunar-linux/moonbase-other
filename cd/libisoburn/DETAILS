    MODULE=libisoburn
   VERSION=1.5.8
    SOURCE=$MODULE-$VERSION.pl02.tar.gz
SOURCE_URL=https://files.libburnia-project.org/releases
SOURCE_VFY=sha256:a977b03dc3686d9fdca600458b1578f9cac2b875609bd5ec21f5ada55f20ec50
  WEB_SITE=https://libburnia-project.org
   ENTERED=20080513
   UPDATED=20260526
     SHORT="A frontend for libraries libburn and libisofs"

cat << EOF
libisoburn is a frontend for libraries libburn and libisofs which enables
creation and expansion of ISO-9660 filesystems on all CD/DVD media supported
by libburn. This includes media like DVD+RW, which do not support multi-session
management on media level and even plain disk files or block devices.
EOF
