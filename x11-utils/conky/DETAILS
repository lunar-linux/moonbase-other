          MODULE=conky
         VERSION=1.23.0
          SOURCE=$MODULE-$VERSION.tar.gz
 SOURCE_URL_FULL=https://github.com/brndnmtthws/conky/archive/v$VERSION.tar.gz
      SOURCE_VFY=sha256:039bdc6d14a355586b462cb0a6ffdeb3e2f9b354a5348dd88f8ad22d4538b783
        WEB_SITE=https://conky.sourceforge.net
         ENTERED=20060221
         UPDATED=20260518
           SHORT="A light-weight system monitor"

cat << EOF
Conky is a program which can display arbitrary information (such as the date,
CPU temperature from i2c, MPD info, and anything else you desire) to the root
window in X11. Conky normally does this by drawing to the root window, however
Conky can also be run in windowed mode (though this is not how conky was meant
to be used).
EOF
