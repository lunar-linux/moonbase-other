         VERSION=1.27.0
          SOURCE=$MODULE-$VERSION.tar.gz
 SOURCE_URL_FULL=https://codeberg.org/dnkl/$MODULE/archive/$VERSION.tar.gz
      SOURCE_VFY=sha256:4e6131cc859ec6a36569f1978cf3617cc3836a681d13d228ded1b4885dab7770
SOURCE_DIRECTORY=$BUILD_DIRECTORY/$MODULE
