          MODULE=gsasl
         VERSION=2.2.4
          SOURCE=$MODULE-$VERSION.tar.gz
      SOURCE_URL=https://ftp.gnu.org/gnu/$MODULE
      SOURCE_VFY=sha256:d32be15efd3a04cb19b232f721bdca02cc6ad7ab415df7d79fb2dd2c0da3e0be
        WEB_SITE=ttps://www.gnu.org/software/$MODULE
         ENTERED=20260712
         UPDATED=20260712
           SHORT="A Simple Authentication and Security Layer framework (SASL)"

cat << EOF
GNU SASL is an implementation of the Simple Authentication and Security Layer
framework and a few common SASL mechanisms. SASL is used by network servers
(e.g., IMAP, SMTP, XMPP) to request authentication from clients, and in clients
to authenticate against servers.
EOF
