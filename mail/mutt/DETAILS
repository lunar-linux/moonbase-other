          MODULE=mutt
         VERSION=2.4.1
          SOURCE=$MODULE-$VERSION.tar.gz
      SOURCE_URL=http://ftp.mutt.org/pub/mutt/
      SOURCE_VFY=sha256:5624321f0b1cc1eff6cab9ef08f25954ff64c51b33d4bf3b99484cf1edd8cfff
        WEB_SITE=http://www.mutt.org/
         ENTERED=20010922
         UPDATED=20260706
           SHORT="A text-based MIME Email client"

cat << EOF
Mutt is a small but very powerful text-based MIME mail client. It is highly
configurable, and is well-suited to the mail power user with advanced features
like key bindings, keyboard macros, mail threading, regular expression searches,
and a powerful pattern matching language for selecting groups of messages.
EOF
