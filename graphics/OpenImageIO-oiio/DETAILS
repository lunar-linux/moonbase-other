          MODULE=OpenImageIO-oiio
         VERSION=3.1.14.1
          SOURCE=OpenImageIO-$VERSION.tar.gz
      SOURCE_URL=https://github.com/AcademySoftwareFoundation/OpenImageIO/releases/download/v$VERSION/
      SOURCE_VFY=sha256:747341fd98f10d82868ec7663f1f3763cf6fb9acf8a2ed81fc3f25256ef019be
SOURCE_DIRECTORY=$BUILD_DIRECTORY/OpenImageIO-$VERSION
        WEB_SITE=http://www.openimageio.org/
         ENTERED=20130329
         UPDATED=20260622
           SHORT="library for reading and writing images"

cat << EOF
OpenImageIO is a library for reading and writing images, and a bunch of related
classes, utilities, and applications. There is a particular emphasis on formats
and functionality used in professional, large-scale animation and visual effects
work for film.
OpenImageIO is used extensively in animation and VFX studios all over the world,
and is also incorporated into several commercial products.
EOF
