          MODULE=taglib
         VERSION=2.2.1
          SOURCE=$MODULE-$VERSION.tar.gz
   SOURCE_URL[0]=https://taglib.org/releases/
   SOURCE_URL[1]=http://developer.kde.org/~wheeler/files/src/
   SOURCE_URL[2]=$MIRROR_URL
      SOURCE_VFY=sha256:7e76b5299dcef427c486bffe455098470c8da91cf3ccb9ea804893df57389b5e
        WEB_SITE=http://developer.kde.org/~wheeler/taglib.html
         ENTERED=20040331
         UPDATED=20260308
           SHORT="Reading and editing the meta-data of several popular audio formats"

cat << EOF
TagLib is a library for reading and editing the meta-data of several
popular audio formats. Currently it supports both ID3v1 and ID3v2 for
MP3 files, Ogg Vorbis comments and ID3 tags and Vorbis comments in FLAC
files.
EOF
