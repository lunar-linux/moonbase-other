          MODULE=gst-plugins-base
         VERSION=1.28.4
          SOURCE=${MODULE%-1*}-$VERSION.tar.xz
      SOURCE_URL=https://gstreamer.freedesktop.org/src/gst-plugins-base
SOURCE_DIRECTORY=$BUILD_DIRECTORY/${MODULE%-1*}-$VERSION
      SOURCE_VFY=sha256:a898afd5766172b0049e6781558e0689098bf87b9d82b846c652e571c01d60d8
        WEB_SITE=https://gstreamer.freedesktop.org/modules/gst-plugins-base.html
         ENTERED=20130103
         UPDATED=20260614
        REPLACES=gst-plugins-base-1.0
           SHORT="The base set of plugins for Gstreamer"

cat << EOF
gst-plugins-base is a well-groomed and well-maintained collection of GStreamer
plug-ins and elements, spanning the range of possible types of elements one
would want to write for GStreamer. It also contains helper libraries and base
classes useful for writing elements. A wide range of video and audio decoders,
encoders, and filters are included.
EOF
