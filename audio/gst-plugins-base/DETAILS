         VERSION=1.29.1
          SOURCE=$MODULE-$VERSION.tar.xz
      SOURCE_URL=https://gstreamer.freedesktop.org/src/gst-plugins-base
      SOURCE_VFY=sha256:b038ea9dae71274d2c2853d51823187972ebd9e4a431a4696942fe0e356ddf40
